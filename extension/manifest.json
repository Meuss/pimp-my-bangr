{
  "manifest_version": 3,
  "name": "Pimp my BANGR",
  "version": "1.0.0",
  "description": "Dark mode theme for the Aubep timesheet tool",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["*://marvelous.aubeperp.ch/*"],
  "content_scripts": [
    {
      "matches": ["*://marvelous.aubeperp.ch/*"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
